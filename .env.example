# ===================================
# API 密钥配置
# ===================================

# 网站配置 API Key（可选）
# 如果设置，则 API 请求需要包含 X-API-Key 请求头
# 如果不设置，则 API 公开访问（推荐，因为联系方式本来就是公开的）
SITE_CONFIG_API_KEY=

# 验证码 API Key（推荐设置！）
# 保护 /api/send-verification 和 /api/verify-code 接口
# 防止被滥用（短信轰炸、邮件轰炸）
# 生产环境强烈建议设置！
API_SECRET_KEY=

# ===================================
# Vercel 部署配置
# ===================================
# 在 Vercel Dashboard 中添加环境变量：
# 1. 进入 Vercel Dashboard
# 2. 选择项目 → Settings → Environment Variables
# 3. 添加上述变量
# 4. 重新部署项目

# ===================================
# 使用说明
# ===================================
# 前端调用需要 API Key 的接口时：
# fetch('/api/send-verification', {
#   method: 'POST',
#   headers: {
#     'X-API-Key': process.env.VITE_API_KEY,
#     'Content-Type': 'application/json'
#   },
#   body: JSON.stringify({ ... })
# })
